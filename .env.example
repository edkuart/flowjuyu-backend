# ==========================
# Servidor
# ==========================
PORT=8800
NODE_ENV=development
APP_URL=http://localhost:8800
FRONTEND_URL=http://localhost:3000

# ==========================
# Base de datos Supabase (Postgres)
# ==========================
# Desarrollo local:
# - usa DB_* por defecto
# - usa DATABASE_URL solo si DB_CONNECTION_MODE=url
DB_CONNECTION_MODE=params
DB_HOST=db.yjoybxvmnfwkuzrthdge.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD= # <-- poner solo en .env real
DB_SSL=true

# ==========================
# JWT
# ==========================
# Generá secretos fuertes (p.ej. openssl rand -base64 48)
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d
SESSION_SECRET=

# ==========================
# Firebase Admin (Google Auth)
# ==========================
# Requeridos para que el backend valide el id_token de Firebase y pueda
# intercambiarlo por la sesión propia (JWT + cookie HttpOnly fj_rt).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY_BASE64=   # base64-encode the PEM: node -e "console.log(Buffer.from(key.private_key).toString('base64'))"

# ==========================
# Supabase Storage
# ==========================
SUPABASE_URL=https://yjoybxvmnfwkuzrthdge.supabase.co
SUPABASE_SERVICE_ROLE= # <-- clave solo en .env real
SUPABASE_BUCKET=uploads

# ==========================
# Seguridad / CORS
# (lista separada por comas)
# ==========================
CORS_ORIGIN_ALLOWLIST=http://localhost:3000,https://flowjuyu.com,https://www.flowjuyu.com,https://flowjuyu-frontend.vercel.app

# ==========================
# Logging / Observabilidad
# ==========================
LOG_LEVEL=info
SENTRY_DSN=

# ==========================
# WhatsApp Cloud API
# ==========================
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_LINK_CODE_TTL_MINUTES=10

# ==========================
# OpenAI
# ==========================
OPENAI_API_KEY=
OPENAI_MODEL_TEXT=gpt-4.1-mini
OPENAI_MODEL_TRANSCRIPTION=gpt-4o-mini-transcribe
OPENAI_MODEL_VISION=gpt-4.1-mini
OPENAI_TIMEOUT_MS=12000
OPENAI_TIMEOUT_MS_VISION=12000

# ==========================
# KYC / Identity Verification
# ==========================
# internal      -> validación local de consistencia, sin OCR real
# openai_vision -> intenta extraer nombre/CUI desde imágenes del DPI
# external_api  -> reservado para Sumsub / proveedor KYC externo
KYC_IDENTITY_PROVIDER=internal
KYC_OPENAI_VISION_MODEL=gpt-4.1-mini
KYC_OPENAI_VISION_TIMEOUT_MS=12000
